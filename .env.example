# Variables de entorno - EJEMPLO (sin valores reales)
# Copia este archivo a .env y rellena con tus valores. NUNCA subas .env al repositorio.

# API (para formularios y servicios)
PUBLIC_API_URL=https://api.example.com

# Deploy estático: origen del sitio/API (sin barra final). Formularios y API de contenido usan PUBLIC_API_BASE.
# Sitio de pruebas Whole Self: https://www.ajamoment.com  |  Desarrollo: http://localhost:4321
PUBLIC_API_BASE=https://www.ajamoment.com

# Base de datos (MySQL - formularios y contenido)
# Formato: mysql://usuario:password@host:3306/nombre_bd
# Para build completo (index.html + páginas de condiciones sin redirect): configura la URL real y ejecuta npm run build:with-db
DATABASE_URL=mysql://user:password@localhost:3306/wholeself_forms

# reCAPTCHA (panel admin y formularios)
# Site key: puede ser pública en el front. Secret key: SOLO en servidor.
PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here

# Contenido desde BD (páginas y equipo). true = leer desde MySQL/API; false = leer desde JSON.
# IMPORTANTE para que el sitio público muestre contenido actualizado al hacer F5 (Augushub):
#   En PRODUCCIÓN el build DEBE usar PUBLIC_USE_CONTENT_FROM_BD=true y PUBLIC_API_BASE con la URL del sitio/API.
#   Así la home (y páginas que usan la API) fetchean GET /api/content/:pageId al cargar y al refrescar.
# En LOCAL (npm run dev): PUBLIC_USE_CONTENT_FROM_BD=false en .env.local para usar JSON y no conectar a MySQL remoto.
# PUBLIC_USE_CONTENT_FROM_BD=true

# Deploy Bluehost: NO poner aquí. Usar GitHub Secrets (FTP_SERVER, FTP_USERNAME, FTP_PASSWORD).
