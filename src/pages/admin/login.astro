---
/**
 * Página de Login - Panel de Administración
 * NO usa BaseLayout (sin header ni footer).
 * Contenido del login definido aquí (sin JSON externo).
 */

import { LoginForm } from '@/components/admin';
import { getLocalizedText } from '@/data/models/ContentPage';
import '../../styles/global.css';

const lang = 'en';

const loginContent = {
  title: { en: 'Panel de Administración', es: 'Panel de Administración' },
  subtitle: { en: 'Access the content management system', es: 'Accede al sistema de gestión de contenido' },
  form: {
    username: { label: { en: 'Usuario', es: 'Usuario' }, placeholder: { en: 'Ej: admin', es: 'Ej: admin' } },
    password: { label: { en: 'Contraseña', es: 'Contraseña' }, placeholder: { en: 'Ej: password123', es: 'Ej: password123' } },
    submit: { en: 'Iniciar Sesión', es: 'Iniciar Sesión' },
    loading: { en: 'Iniciando sesión...', es: 'Iniciando sesión...' },
    errors: {
      invalidCredentials: { en: 'Usuario o contraseña incorrectos', es: 'Usuario o contraseña incorrectos' },
      recaptchaFailed: { en: 'Verificación reCAPTCHA fallida. Por favor, intente nuevamente.', es: 'Verificación reCAPTCHA fallida. Por favor, intente nuevamente.' },
      required: { en: 'Por favor, complete todos los campos', es: 'Por favor, complete todos los campos' },
      network: { en: 'Error de conexión. Por favor, intente nuevamente.', es: 'Error de conexión. Por favor, intente nuevamente.' },
    },
  },
};

const seoTitle = 'Admin Panel - Whole Self Counseling';
const seoDescription = 'Administrative panel for content management';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={seoDescription} />
    <link rel="icon" type="image/svg+xml" href={`${(import.meta.env.BASE_URL || '/')}favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <title>{seoTitle}</title>
  </head>
  <body class="min-h-screen bg-gray-50 flex items-center justify-center px-4">
    <div class="w-full max-w-md">
      <!-- Logo y título -->
      <div class="text-center mb-8">
        <img 
          src={`${(import.meta.env.BASE_URL || '/')}logo.svg`} 
          alt="Whole Self Counseling" 
          class="h-16 mx-auto mb-4"
          width="64"
          height="64"
        />
        <h1 class="text-2xl font-semibold text-gray-900 mb-2">
          {getLocalizedText(loginContent.title, lang)}
        </h1>
        {loginContent.subtitle && (
          <p class="text-gray-600 text-sm">
            {getLocalizedText(loginContent.subtitle, lang)}
          </p>
        )}
      </div>
      
      <!-- Formulario de login -->
      <div class="bg-white rounded-lg shadow-md p-8">
        <LoginForm client:load loginContent={loginContent} language={lang} />
      </div>
    </div>
  </body>
</html>
