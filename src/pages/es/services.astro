---
/**
 * Página Services (es) - Contenido desde API en el cliente vía ServicesContentFromApi.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getPageContent, getLocalizedText } from '@/data/services/contentService';
import { getLocaleFromPathname } from '@/utils/i18n';
import PageHeroFromApi from '@/components/shared/PageHeroFromApi';
import ServicesContentFromApi from '@/components/services/ServicesContentFromApi';

const lang = getLocaleFromPathname(Astro.url.pathname);
const servicesData = await getPageContent('services', lang);
const pageTitle = getLocalizedText(servicesData.seo?.title, lang);
---

<BaseLayout title={pageTitle}>
  <PageHeroFromApi client:load pageId="services" lang={lang} initialData={servicesData} />
  <ServicesContentFromApi client:load lang={lang} initialData={servicesData} />
</BaseLayout>

