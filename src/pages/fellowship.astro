---
/**
 * Fellowship Page - Whole Self Counseling
 * Contenido refetcheado desde API en el cliente para que los cambios del editor se vean en vivo.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getPageContent, getLocalizedText } from '@/data/services/contentService';
import { getLocaleFromPathname } from '@/utils/i18n';
import FellowshipContentFromApi from '@/components/fellowship/FellowshipContentFromApi';

const lang = getLocaleFromPathname(Astro.url.pathname);
const fellowshipData = await getPageContent('fellowship');
const pageTitle = getLocalizedText(fellowshipData.seo.title, lang);
const pageDescription = getLocalizedText(fellowshipData.seo.description, lang);
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <FellowshipContentFromApi client:load lang={lang} initialData={fellowshipData} />
</BaseLayout>
