---
/**
 * Página Contact - Whole Self Counseling
 * Contenido refetcheado desde API en el cliente para que los cambios del editor se vean en vivo.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getPageContent, getLocalizedText } from '@/data/services/contentService';
import { getLocaleFromPathname } from '@/utils/i18n';
import ContactContentFromApi from '@/components/contact/ContactContentFromApi';

const lang = getLocaleFromPathname(Astro.url.pathname);
const contactData = await getPageContent('contact', lang);
const pageTitle = getLocalizedText(contactData.seo.title, lang);
---

<BaseLayout title={pageTitle}>
  <ContactContentFromApi client:load lang={lang} initialData={contactData} />
</BaseLayout>

