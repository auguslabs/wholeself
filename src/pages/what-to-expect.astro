---
/**
 * Página What to Expect - Whole Self Counseling
 * Contenido refetcheado desde API en el cliente para que los cambios del editor se vean en vivo.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getPageContent, getLocalizedText } from '@/data/services/contentService';
import { getLocaleFromPathname } from '@/utils/i18n';
import WhatToExpectContentFromApi from '@/components/what-to-expect/WhatToExpectContentFromApi';

const lang = getLocaleFromPathname(Astro.url.pathname);
const whatToExpectData = await getPageContent('what-to-expect', lang);
const pageTitle = getLocalizedText(whatToExpectData.seo.title, lang);
---

<BaseLayout title={pageTitle}>
  <WhatToExpectContentFromApi client:load lang={lang} initialData={whatToExpectData} />
</BaseLayout>
