---
/**
 * Página Crisis Resources - Whole Self Counseling
 * Contenido refetcheado desde API en el cliente para que los cambios del editor se vean en vivo.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getPageContent, getLocalizedText } from '@/data/services/contentService';
import { getLocaleFromPathname } from '@/utils/i18n';
import CrisisResourcesContentFromApi from '@/components/crisis-resources/CrisisResourcesContentFromApi';

const lang = getLocaleFromPathname(Astro.url.pathname);
const crisisData = await getPageContent('crisis-resources');
const pageTitle = getLocalizedText(crisisData.seo.title, lang);
const pageDescription = getLocalizedText(crisisData.seo.description, lang);
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <CrisisResourcesContentFromApi client:load lang={lang} initialData={crisisData} />
</BaseLayout>

